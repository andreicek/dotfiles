theme = dark:"Builtin Solarized Dark",light:"Builtin Solarized Light"

shell-integration = fish
clipboard-read = "allow"
clipboard-paste-protection = false

font-family = "TX-02"
font-size = 15

macos-option-as-alt = true
macos-titlebar-proxy-icon = hidden

window-padding-x = 10
window-padding-y = 10

keybind = super+r=reload_config
keybind = super+right=goto_split:right
keybind = super+left=goto_split:left
keybind = super+up=goto_split:up
keybind = super+down=goto_split:down
keybind = super+shift+z=toggle_split_zoom

window-save-state = always
unfocused-split-opacity = 1

