#!/usr/bin/env bash
set -euo pipefail

git fetch --prune

current=$(git branch --show-current)

protected=()
deletable=()

for branch in $(git for-each-ref --format='%(refname:short)' refs/heads/); do
  case "$branch" in
    master|main|staging|"$current")
      protected+=("$branch")
      ;;
    *)
      deletable+=("$branch")
      ;;
  esac
done

if [ ${#deletable[@]} -eq 0 ]; then
  echo "No branches to clean up."
  exit 0
fi

for branch in "${protected[@]}"; do
  gum style --foreground 240 "  $branch"
done

selected=$(gum choose --no-limit --header "Select branches to delete:" "${deletable[@]}") || exit 0

if [ -z "$selected" ]; then
  exit 0
fi

while IFS= read -r branch; do
  git branch -D "$branch"
done <<< "$selected"
