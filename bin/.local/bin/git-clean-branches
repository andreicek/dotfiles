#!/usr/bin/env bash
set -euo pipefail

git fetch --prune

current=$(git branch --show-current)
stale=""

for branch in $(git for-each-ref --format='%(refname:short)' refs/heads/); do
  [ "$branch" = "$current" ] && continue
  case "$branch" in master|main|staging) continue ;; esac

  # check if branch tip is reachable from any other branch
  merged_into=$(git branch -a --contains "$branch" 2>/dev/null | grep -v "^\*" | grep -v "  $branch$" | head -1)
  if [ -n "$merged_into" ]; then
    stale="$stale $branch"
  fi
done

if [ -z "$stale" ]; then
  echo "No merged branches to clean up."
  exit 0
fi

echo "Branches merged into another branch:"
for branch in $stale; do
  merged_into=$(git branch -a --contains "$branch" 2>/dev/null | grep -v "^\*" | grep -v "  $branch$" | head -3 | sed 's/^  //')
  echo "  $branch -> $merged_into"
done
echo

read -p "Delete all? [y/N] " confirm
if [[ "$confirm" =~ ^[Yy]$ ]]; then
  for branch in $stale; do
    git branch -D "$branch"
  done
fi
